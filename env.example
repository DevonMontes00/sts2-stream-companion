# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# Your bot account's OAuth token.
# Get one at https://twitchapps.com/tmi/ while logged in as your BOT account.
# Must include the "oauth:" prefix.
TWITCH_TOKEN=oauth:your_token_here

# The username of your bot account (lowercase).
TWITCH_BOT_NICK=your_bot_name

# Your channel name — the streamer account (no # needed).
TWITCH_CHANNEL=your_channel_name

# Anthropic API key for AI-generated commentary.
# Get one at https://console.anthropic.com/
# If left empty, all messages fall back to static text silently.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Twitch Predictions (optional) ──────────────────────────────────────────
# All three values must be set to enable boss-fight predictions.
#
# TWITCH_CLIENT_ID: your Twitch application's client ID.
#   Create an app at https://dev.twitch.tv/console/apps
#
# TWITCH_BROADCASTER_ID: your channel's numeric user ID.
#   Look it up at https://www.streamweasels.com/tools/convert-twitch-username-to-user-id/
#
# TWITCH_BROADCASTER_TOKEN: a user access token for the BROADCASTER account
#   (NOT the bot account) WITHOUT the 'oauth:' prefix.
#   Needs scope: channel:manage:predictions
#   Generate one at https://twitchapps.com/tokengen/
#   (enter your Client ID above and tick channel:manage:predictions)
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_BROADCASTER_ID=12345678
TWITCH_BROADCASTER_TOKEN=your_broadcaster_token_here
